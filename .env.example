# Google Analytics 4
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your_api_secret_here

# Measurement Protocol API
# Usado para enviar eventos do servidor para o GA4
# Como obter:
# 1. Acesse Google Analytics > Admin > Fluxos de dados
# 2. Clique no seu fluxo de dados
# 3. Role até "Measurement Protocol API secrets"
# 4. Crie uma nova chave secreta
# 5. Copie o valor e cole aqui
